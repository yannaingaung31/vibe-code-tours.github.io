---
interface Props {
  name: string;
  github: string;
  role: "builder" | "mentor" | "instructor";
  skills?: string[];
  repo?: string;
  x?: string;
  linkedin?: string;
  website?: string;
  certs?: Record<string, string>;
}

const { name, github, role, skills, repo, x, linkedin, website, certs } =
  Astro.props;

import { certDisplayList } from "../lib/certs.mjs";
const certList = certDisplayList(certs);

const avatar = `https://github.com/${github}.png?size=160`;
const roleClass =
  role === "instructor" ? "tier-c" : role === "mentor" ? "tier-b" : "tier-a";

// Normalize a handle-or-URL into a full URL.
const url = (val: string | undefined, base: string) =>
  !val
    ? undefined
    : val.startsWith("http")
      ? val
      : base + val.replace(/^@/, "");

// GitHub is already shown via the avatar + @handle link above — not repeated here.
const links = [
  { label: "Repo", href: repo, show: !!repo },
  { label: "X", href: url(x, "https://x.com/"), show: !!x },
  {
    label: "LinkedIn",
    href: url(linkedin, "https://linkedin.com/in/"),
    show: !!linkedin,
  },
  { label: "Web", href: website, show: !!website },
].filter((l) => l.show);
---

{
  /*
  Pop-out card. In a CSS grid the row height is held by sibling cells, so on
  hover/focus the inner card switches to `absolute` and grows over the row
  below (z-index) without reflowing the grid. tabindex makes it work for
  touch + keyboard, not just mouse hover.
*/
}
<div
  class="builder-cell group relative"
  data-role={role}
  data-skills={(skills ?? []).join("|")}
>
  <article
    tabindex="0"
    class:list={[
      "card flex cursor-pointer flex-col outline-none transition-shadow duration-200",
      "group-hover:absolute group-hover:inset-x-0 group-hover:top-0 group-hover:z-30",
      "group-hover:shadow-2xl group-hover:shadow-black/60 group-hover:ring-1 group-hover:ring-accent-500/40",
      "group-focus-within:absolute group-focus-within:inset-x-0 group-focus-within:top-0 group-focus-within:z-30",
      "group-focus-within:shadow-2xl group-focus-within:shadow-black/60 group-focus-within:ring-1 group-focus-within:ring-accent-500/40",
    ]}
  >
    <div class="flex items-center gap-3">
      <img
        src={avatar}
        alt={`${name} avatar`}
        width="48"
        height="48"
        loading="lazy"
        class="h-12 w-12 shrink-0 rounded-full border border-accent-500/30 bg-surface-elevated object-cover"
      />
      <div class="min-w-0">
        <p class="truncate font-bold text-white">{name}</p>
        <a
          href={`https://github.com/${github}`}
          target="_blank"
          rel="noopener"
          class="font-mono text-xs text-gray-500 no-underline hover:text-accent-500"
        >
          @{github}
        </a>
      </div>
      <span class:list={["tier", roleClass, "ml-auto shrink-0"]} title={role}>
        {role[0].toUpperCase()}
      </span>
    </div>

    <div
      class="mt-2.5 flex items-center gap-1.5"
      aria-label="Claude certifications"
    >
      {
        certList.map((c) =>
          c.earned ? (
            <a
              href={c.url}
              target="_blank"
              rel="noopener"
              class="cert-star"
              style={`color:${c.color}`}
              title={`${c.label} — verified ✓`}
              aria-label={`${c.label}: verified`}
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="cert-ico"
              >
                <Fragment set:html={c.icon} />
              </svg>
            </a>
          ) : (
            <span
              class="cert-star cert-off"
              style={`color:${c.color}`}
              title={`${c.label} — not yet earned`}
              aria-label={`${c.label}: not earned`}
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="cert-ico"
              >
                <Fragment set:html={c.icon} />
              </svg>
            </span>
          ),
        )
      }
    </div>

    {
      skills && skills.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {skills.map((skill) => (
            <span class="rounded-full border border-white/10 bg-white/5 px-2 py-0.5 font-mono text-[10px] font-semibold text-gray-400">
              {skill}
            </span>
          ))}
        </div>
      )
    }

    <div
      class="prose-builder mt-3 line-clamp-3 text-sm text-gray-400 group-focus-within:line-clamp-none group-focus-within:max-h-72 group-focus-within:overflow-y-auto group-hover:line-clamp-none group-hover:max-h-72 group-hover:overflow-y-auto"
    >
      <slot />
    </div>

    <div
      class="mt-4 flex flex-wrap gap-x-4 gap-y-1 border-t border-white/5 pt-3 text-xs font-semibold"
    >
      {
        links.map((l) => (
          <a
            href={l.href}
            target="_blank"
            rel="noopener"
            class="text-gray-500 no-underline hover:text-accent-500"
          >
            {l.label}
          </a>
        ))
      }
    </div>
  </article>
</div>

<style>
  .prose-builder :global(p) {
    margin: 0;
  }
  .prose-builder :global(p + p) {
    margin-top: 0.5rem;
  }
  .cert-star {
    display: inline-flex;
    align-items: center;
    line-height: 1;
    text-decoration: none;
    transition:
      transform 0.15s ease,
      filter 0.15s ease;
    cursor: default;
  }
  .cert-ico {
    width: 1.05rem;
    height: 1.05rem;
    display: block;
  }
  a.cert-star {
    cursor: pointer;
  }
  a.cert-star:hover {
    transform: scale(1.25);
    filter: drop-shadow(0 0 6px currentColor);
  }
  .cert-off {
    opacity: 0.55;
  }

  /* Keep the grid cell from collapsing when the card pops to absolute. */
  .builder-cell {
    min-height: 100%;
  }
</style>
